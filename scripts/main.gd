var chapters_diff_popup_level: int = -1  # Level index for difficulty picker popup (-1 = closed)

func _draw_story_map() -> void:
	var font = game_font
	var list_x = 24.0 + _safe_left
	var list_y = 36.0
	var list_w = 1060.0
	var list_h = 575.0
	var row_h = 136.0
	var header_h = 36.0
	var arc_gap = 8.0

	# --- Background panel (Bloons-style bordered panel with shadow) ---
	_ds_panel(Rect2(list_x, list_y, list_w, list_h), Color(0.06, 0.04, 0.10, 0.92), Color(0.35, 0.20, 0.50, 0.6), 3.0)

	# --- Title bar (Bloons-style gradient header) ---
