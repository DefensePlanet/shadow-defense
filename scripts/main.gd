func _draw_story_portrait(px: float, py: float, size: float, speaker: String) -> void:
	# --- TEXTURE-BASED PORTRAIT SYSTEM ---
	# Loads pre-generated AI portrait PNGs instead of procedural draw calls.
	var s = size / 350.0
	var cx = px + size * 0.5
	var cy = py + size * 0.5

	# Get glow color for background effects
	var glow_col = _get_character_glow_color(speaker)

	# Background glow aura (behind portrait)
	var glow_pulse = 0.3 + sin(_time * 1.5) * 0.1
	for gi in range(4):
		var gr = (65.0 + float(gi) * 18.0) * s
		var ga = glow_pulse * (0.12 - float(gi) * 0.025)
		draw_circle(Vector2(cx, cy), gr, _ca(glow_col, maxf(ga, 0.0)))

	# Draw the portrait texture if loaded
	if speaker in _portrait_textures and _portrait_textures[speaker] != null:
		var tex = _portrait_textures[speaker]
		var tex_size = tex.get_size()
		# Scale to fit within the portrait area with some padding
		var portrait_scale = (size * 0.85) / maxf(tex_size.x, tex_size.y)
		var draw_w = tex_size.x * portrait_scale
		var draw_h = tex_size.y * portrait_scale
		var draw_x = cx - draw_w * 0.5
		var draw_y = cy - draw_h * 0.5
		# Subtle breathing animation
		var breath = sin(_time * 1.8) * 1.5 * s
		draw_y += breath
		# Draw with slight sway
		var sway = sin(_time * 0.7) * 1.0 * s
		draw_x += sway
		draw_texture_rect(tex, Rect2(draw_x, draw_y, draw_w, draw_h), false)
	else:
		# Fallback: styled silhouette for missing portraits
		# Dark filled body shape
		draw_colored_polygon(PackedVector2Array([
			Vector2(cx - 30*s, cy - 50*s), Vector2(cx + 30*s, cy - 50*s),
			Vector2(cx + 35*s, cy + 80*s), Vector2(cx - 35*s, cy + 80*s)
		]), Color(glow_col.r * 0.15, glow_col.g * 0.15, glow_col.b * 0.15, 0.8))
		# Head circle
		draw_circle(Vector2(cx, cy - 65*s), 22*s, Color(glow_col.r * 0.2, glow_col.g * 0.2, glow_col.b * 0.2, 0.8))
		# Glow outline
		draw_arc(Vector2(cx, cy - 65*s), 23*s, 0, TAU, 24, _ca(glow_col, 0.4), 1.5*s)
		# Glow dot for unknown character
		draw_circle(Vector2(cx, cy - 60*s), 4*s, _ca(glow_col, 0.5))

	# Subtle rim light on portrait edge
	var rim_pulse = 0.15 + sin(_time * 2.0) * 0.05
	draw_arc(Vector2(cx, cy), size * 0.42, 0, TAU, 32, _ca(glow_col, rim_pulse * 0.3), 1.5*s)


