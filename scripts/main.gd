			var spark_alpha := spark_active * 0.7
			for sp in range(3):
				var sa := float(sp) * TAU / 3.0 + _time * 5.0
				var sr := 15.0 + float(sp) * 8.0
				var sx2 := tx + cos(sa) * sr
