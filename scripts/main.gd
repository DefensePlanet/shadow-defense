func _toggle_gear_lock(gear_id: String) -> void:
	if locked_gear.get(gear_id, false):
		locked_gear.erase(gear_id)
	else:
		locked_gear[gear_id] = true
	_save_game()

func _is_gear_locked(gear_id: String) -> bool:
	return locked_gear.get(gear_id, false)

