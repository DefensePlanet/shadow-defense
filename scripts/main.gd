		var drip_w := 2.0 + sin(float(dr) * 1.3) * 1.0
		draw_rect(Rect2(dx - drip_w / 2, dy, drip_w, 18 + sin(float(dr)) * 6.0), Color(0.05, 0.02, 0.08, 0.4))
	# Floating open books (larger)
