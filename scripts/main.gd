func _calculate_wave_danger(w: int) -> int:
	var danger = 1
	var pct = float(w) / float(maxi(total_waves, 1))
	if pct > 0.8:
		danger = 5
	elif pct > 0.6:
		danger = 4
	elif pct > 0.4:
		danger = 3
	elif pct > 0.2:
		danger = 2
	# Boss waves are always more dangerous
	if w % 10 == 0 or w == total_waves:
		danger = mini(danger + 1, 5)
	# Difficulty modifier
	if selected_difficulty >= 2:
		danger = mini(danger + 1, 5)
	return danger

