func _apply_font_to_controls(node: Node) -> void:
	if game_font == null:
		return
	if node is Label:
		node.add_theme_font_override("font", game_font)
	elif node is Button:
		node.add_theme_font_override("font", game_font)
	for child in node.get_children():
		_apply_font_to_controls(child)

