	var spark := sin(_time * 8.0 + float(ch)) * 0.3
	if spark > 0.0:
		draw_line(Vector2(lab_x + 14, lab_y - 30), Vector2(lab_x + 14 + sin(_time * 12.0) * 10.0, lab_y - 40), Color(0.5, 0.6, 0.9, spark), 1.5)
