		for ring in range(5):
			var ry := 440.0 + float(ring) * 15.0
			draw_arc(Vector2(tx, ry), 10.0, 0, TAU, 16, Color(0.15, 0.12, 0.08), 2.0)
		# Sparks from top
		var spark_active := sin(_time * 8.0 + float(tc) * 2.5)
