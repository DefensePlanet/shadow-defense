func _draw_daily_deals_sidebar(px: float, py: float, pw: float, ph: float) -> void:
	var font = game_font
	# Improvement 4: Countdown timer
	var date = Time.get_date_dict_from_system()
	var time_dict = Time.get_time_dict_from_system()
	var hours_left = 23 - time_dict["hour"]
	var mins_left = 59 - time_dict["minute"]
	var countdown_str = "Resets in %dh %dm" % [hours_left, mins_left]
	var is_weekend = date["weekday"] == 0 or date["weekday"] == 6
	_ds_outlined_text(Vector2(px + 10, py + 18), "DAILY DEALS" + (" — WEEKEND!" if is_weekend else ""), 16, Color(1.0, 0.85, 0.28), int(pw - 20), HORIZONTAL_ALIGNMENT_CENTER)
	_udraw(font, Vector2(px + pw * 0.5, py + 36), countdown_str, HORIZONTAL_ALIGNMENT_CENTER, -1, 14, Color(0.7, 0.55, 0.2, 0.7 + sin(_time * 2.0) * 0.15))
	# Improvement 5: Refresh button
	var ref_x = px + pw - 130.0
	var ref_y = py + 8.0
	var mouse_pos = get_viewport().get_mouse_position()
	var ref_btn_h = 44.0 if _is_mobile else 28.0
	var ref_hov = _is_hover_or_pressed(Rect2(ref_x, ref_y, 120, ref_btn_h), mouse_pos)
	_ds_button(Rect2(ref_x, ref_y, 120, ref_btn_h), "REFRESH %dQ" % DEAL_REFRESH_COST, Color(0.30, 0.20, 0.08), ref_hov, 12)
	var card_y = py + 48.0
	for i in range(daily_deals.size()):
		var deal = daily_deals[i]
		var is_featured = deal.get("featured", false)
		var deal_rarity = deal.get("tier", "common")
		var rarity_col = DEAL_TIER_COLORS.get(deal_rarity, Color(0.6, 0.6, 0.6))
		var ix = px + 10
		var ih = 72.0 if is_featured else 56.0  # Improvement 3: Featured is larger
		var iy = card_y
		var iw = pw - 20
		card_y += ih + 6.0
		var purchased = daily_deals_purchased[i] if i < daily_deals_purchased.size() else false
		# Improvement 9: Purchase flash animation
		var flash_alpha = 0.0
		for pf in _deal_purchase_flash:
			if pf["index"] == i:
				flash_alpha = clampf(pf["timer"], 0.0, 1.0)
		# Background with rarity tint — rounded panel (Improvement 1)
		var bg_col = Color(0.08, 0.20, 0.08, 0.65) if purchased else Color(rarity_col.r * 0.14, rarity_col.g * 0.14, rarity_col.b * 0.14, 0.78)
		var border_alpha = 0.5 + sin(_time * 2.5 + float(i)) * 0.15
		if deal_rarity == "legendary":
			border_alpha = 0.7 + sin(_time * 3.0) * 0.25
		_ds_panel(Rect2(ix, iy, iw, ih), bg_col, Color(rarity_col.r, rarity_col.g, rarity_col.b, border_alpha), 2.0 if is_featured else 1.5, 8.0)
		# Featured badge (Improvement 3)
		if is_featured:
			draw_rect(Rect2(ix + 2, iy + 2, 65, 16), Color(rarity_col.r, rarity_col.g, rarity_col.b, 0.25))
			_udraw(font, Vector2(ix + 35, iy + 14), "FEATURED", HORIZONTAL_ALIGNMENT_CENTER, -1, 14, rarity_col)
		# Rarity badge
		var badge_y_off = 16.0 if is_featured else 0.0
		_udraw(font, Vector2(ix + iw - 15, iy + 14 + badge_y_off), deal_rarity.to_upper(), HORIZONTAL_ALIGNMENT_RIGHT, -1, 14, Color(rarity_col.r, rarity_col.g, rarity_col.b, 0.7))
		# Deal name and description
		var name_y = iy + 20 + badge_y_off
		if not purchased:
			_ds_outlined_text(Vector2(ix + 10, name_y), deal.get("name", "Deal"), 15, Color(0.95, 0.85, 0.6), int(iw - 140), HORIZONTAL_ALIGNMENT_LEFT, 1)
		else:
			_udraw(font, Vector2(ix + 10, name_y), deal.get("name", "Deal"), HORIZONTAL_ALIGNMENT_LEFT, int(iw - 140), 15, Color(0.5, 0.5, 0.4))
		_udraw(font, Vector2(ix + 10, name_y + 18), deal.get("desc", ""), HORIZONTAL_ALIGNMENT_LEFT, int(iw - 140), 14, menu_text_muted if not purchased else Color(0.35, 0.35, 0.3))
		if purchased:
			# Improvement 10: Enhanced sold-out visual with checkmark
			draw_rect(Rect2(ix + iw - 90, iy + ih * 0.5 - 14, 78, 28), Color(0.12, 0.28, 0.12, 0.82))
			draw_rect(Rect2(ix + iw - 90, iy + ih * 0.5 - 14, 78, 28), Color(0.3, 0.7, 0.2, 0.4), false, 1.5)
			_udraw(font, Vector2(ix + iw - 51, iy + ih * 0.5 + 6), "SOLD", HORIZONTAL_ALIGNMENT_CENTER, -1, 15, Color(0.4, 0.75, 0.3))
			# Checkmark
			var cx = ix + iw - 85.0
			var cy = iy + ih * 0.5 - 2.0
			draw_line(Vector2(cx, cy), Vector2(cx + 5, cy + 6), Color(0.4, 0.8, 0.3), 2.0)
			draw_line(Vector2(cx + 5, cy + 6), Vector2(cx + 14, cy - 4), Color(0.4, 0.8, 0.3), 2.0)
		else:
			# Improvement 2: Discount display
			var cost = deal.get("cost", 0)
			var original = deal.get("original_cost", cost)
			var discount_pct = 0
			if original > cost:
				discount_pct = int((1.0 - float(cost) / float(original)) * 100)
			var cost_str = "%d %s" % [cost, deal.get("cost_type", "").capitalize()]
			# Confirm state
			if _deal_confirm_index == i and _deal_confirm_timer > 0.0:
				_ds_button(Rect2(ix + iw - 105, iy + ih * 0.5 - 18, 93, 36), "CONFIRM", Color(0.55, 0.42, 0.10), true, 14)
				var bar_fill = clampf(_deal_confirm_timer / 3.0, 0.0, 1.0)
				if bar_fill > 0.05:
					draw_colored_polygon(_rrp(Rect2(ix + iw - 103, iy + ih * 0.5 + 14, 89 * bar_fill, 3), 1.5), _ca(c_gold_bright, 0.7))
			else:
				var _deal_hov = Rect2(ix + iw - 105, iy + ih * 0.5 - 18, 93, 36).has_point(get_viewport().get_mouse_position())
				draw_colored_polygon(_rrp(Rect2(ix + iw - 105, iy + ih * 0.5 - 18, 93, 36), 8.0), Color(0.15, 0.12, 0.08, 0.9 if _deal_hov else 0.8))
				# Original price (crossed out) — Improvement 2
				if discount_pct > 10:
					_udraw(font, Vector2(ix + iw - 58, iy + ih * 0.5 - 8), "%d" % original, HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.5, 0.4, 0.3))
					# Strikethrough line
					var orig_str = "%d" % original
					var str_w = float(orig_str.length()) * 6.5
					draw_line(Vector2(ix + iw - 58 - str_w * 0.5, iy + ih * 0.5 - 5), Vector2(ix + iw - 58 + str_w * 0.5, iy + ih * 0.5 - 5), Color(0.8, 0.3, 0.2, 0.7), 1.5)
					# Discount badge (rounded)
					draw_colored_polygon(_rrp(Rect2(ix + iw - 105, iy + ih * 0.5 - 18, 32, 14), 4.0), Color(0.7, 0.15, 0.1, 0.8))
					_udraw(font, Vector2(ix + iw - 89, iy + ih * 0.5 - 8), "-%d%%" % discount_pct, HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(1.0, 0.85, 0.7))
				_udraw(font, Vector2(ix + iw - 58, iy + ih * 0.5 + 8), cost_str, HORIZONTAL_ALIGNMENT_CENTER, -1, 14, menu_gold)
		# Flash overlay (Improvement 9)
		if flash_alpha > 0.0:
			draw_rect(Rect2(ix, iy, iw, ih), Color(1.0, 0.9, 0.5, flash_alpha * 0.4))
	# Improvement 7: Buy-all bonus indicator
	var all_purchased = true
	for i in range(daily_deals.size()):
		if i < daily_deals_purchased.size() and not daily_deals_purchased[i]:
			all_purchased = false
			break
	if daily_deals.size() > 0:
		var bonus_y = card_y + 4.0
		if all_purchased and not daily_deals_all_bonus_claimed:
			_ds_panel(Rect2(px + 10, bonus_y, pw - 20, 32), Color(0.15, 0.25, 0.1, 0.8), Color(0.5, 0.9, 0.3, 0.5), 2.0, 8.0)
			_ds_outlined_text(Vector2(px + pw * 0.5, bonus_y + 22), "ALL PURCHASED! CLAIM +15 SHARDS BONUS", 14, Color(0.5, 0.9, 0.3), int(pw - 40), HORIZONTAL_ALIGNMENT_CENTER, 1)
		elif daily_deals_all_bonus_claimed:
			_udraw(font, Vector2(px + pw * 0.5, bonus_y + 18), "Buy-All Bonus Claimed!", HORIZONTAL_ALIGNMENT_CENTER, -1, 14, Color(0.4, 0.6, 0.3))
		elif not all_purchased:
			var bought_count = 0
			for i in range(daily_deals_purchased.size()):
				if daily_deals_purchased[i]:
					bought_count += 1
			_udraw(font, Vector2(px + pw * 0.5, bonus_y + 18), "Buy all %d for +15 Shards bonus (%d/%d)" % [daily_deals.size(), bought_count, daily_deals.size()], HORIZONTAL_ALIGNMENT_CENTER, int(pw - 30), 14, Color(0.6, 0.5, 0.35))

func _draw_quest_panel_sidebar(px: float, py: float, pw: float, ph: float) -> void:
	var font = game_font
	var mouse_pos = get_viewport().get_mouse_position()
	# Improvement 13: Quest streak display
	var streak_str = "Streak: %d day%s" % [quest_streak, "s" if quest_streak != 1 else ""]
	if quest_streak_best > 0:
		streak_str += " (Best: %d)" % quest_streak_best
	_ds_outlined_text(Vector2(px + 10, py + 18), "DAILY QUESTS", 16, Color(0.45, 0.9, 0.35), int(pw - 20), HORIZONTAL_ALIGNMENT_CENTER)
	_udraw(font, Vector2(px + pw * 0.5, py + 34), streak_str, HORIZONTAL_ALIGNMENT_CENTER, -1, 14, Color(0.6, 0.75, 0.4))
	# Improvement 19: Quest milestone counter
	var next_milestone = 0
	for m in QUEST_MILESTONE_THRESHOLDS:
		if total_quests_completed < m:
			next_milestone = m
			break
	if next_milestone > 0:
		_udraw(font, Vector2(px + pw * 0.5, py + 50), "Lifetime: %d/%d quests" % [total_quests_completed, next_milestone], HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.5, 0.55, 0.4))
	else:
		_udraw(font, Vector2(px + pw * 0.5, py + 50), "Lifetime: %d quests completed!" % total_quests_completed, HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.7, 0.8, 0.4))
	var card_y = py + 60.0
	# --- Daily quests ---
	for i in range(active_quests.size()):
		var q = active_quests[i]
		var iy = card_y
		var ih = 60.0
		card_y += ih + 4.0
		var completed = q.get("completed", false)
		var claimed = q.get("claimed", false)
		var difficulty = q.get("difficulty", 0)
		# Improvement 11: Difficulty tier colors
		var diff_colors = [Color(0.4, 0.75, 0.35), Color(0.85, 0.7, 0.25), Color(0.85, 0.3, 0.25)]
		var diff_names = ["EASY", "MEDIUM", "HARD"]
		var diff_col = diff_colors[clampi(difficulty, 0, 2)]
		# Background — rounded card
		var bg = Color(0.06, 0.14, 0.06, 0.55) if claimed else (Color(0.12, 0.24, 0.08, 0.72) if completed else Color(0.10, 0.10, 0.14, 0.65))
		_ds_panel(Rect2(px + 8, iy, pw - 16, ih), bg, Color(diff_col.r, diff_col.g, diff_col.b, 0.3 if not completed else 0.15), 1.0, 8.0)
		# Claim flash animation (Improvement 14)
		var claim_flash = 0.0
		for cf in _quest_claim_flash:
			if cf["index"] == i:
				claim_flash = clampf(cf["timer"], 0.0, 1.0)
		if claim_flash > 0.0:
			draw_colored_polygon(_rrp(Rect2(px + 8, iy, pw - 16, ih), 8.0), Color(0.4, 0.9, 0.3, claim_flash * 0.35))
		# Difficulty badge (Improvement 11)
		draw_rect(Rect2(px + 10, iy + 2, 55, 18), Color(diff_col.r, diff_col.g, diff_col.b, 0.2))
		_udraw(font, Vector2(px + 38, iy + 15), diff_names[clampi(difficulty, 0, 2)], HORIZONTAL_ALIGNMENT_CENTER, -1, 14, diff_col)
		# Quest description
		_udraw(font, Vector2(px + 16, iy + 30), q.get("desc", ""), HORIZONTAL_ALIGNMENT_LEFT, int(pw - 150), 14, Color(0.8, 0.75, 0.6) if not claimed else Color(0.45, 0.45, 0.4))
		# Progress bar
		var pct = float(q.get("progress", 0)) / float(max(1, q.get("target", 1)))
		var bar_w = 100.0
		var bar_x = px + pw - 120.0
		draw_colored_polygon(_rrp(Rect2(bar_x, iy + 8, bar_w, 12), 4.0), Color(0.12, 0.12, 0.12))
		var bar_col = Color(0.2, 0.5, 0.2) if claimed else (Color(0.3, 0.85, 0.3) if completed else Color(0.3, 0.6, 0.3))
		if pct > 0.01:
			draw_colored_polygon(_rrp(Rect2(bar_x, iy + 8, bar_w * clampf(pct, 0.0, 1.0), 12), 4.0), bar_col)
		_udraw(font, Vector2(bar_x + bar_w * 0.5, iy + 18), "%d/%d" % [q.get("progress", 0), q.get("target", 1)], HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.85, 0.85, 0.85))
		# Reward display
		var reward_str = "+%d %s" % [q.get("reward_amount", 0), q.get("reward_type", "").capitalize()]
		if claimed:
			_udraw(font, Vector2(px + pw - 70, iy + 48), "CLAIMED", HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.35, 0.55, 0.3))
		elif completed:
			# Improvement 14 & 20: Animated CLAIM button
			var claim_pulse = 0.7 + sin(_time * 4.0 + float(i)) * 0.3
			var btn_x = px + pw - 115.0
			var btn_y = iy + 32.0
			var claim_h = 44.0 if _is_mobile else 24.0
			var btn_hov = _is_hover_or_pressed(Rect2(btn_x, btn_y, 95, claim_h), mouse_pos)
			_ds_button(Rect2(btn_x, btn_y, 95, claim_h), "CLAIM!", Color(0.15, 0.45, 0.12), btn_hov, 13)
			_udraw(font, Vector2(px + 16, iy + 48), reward_str, HORIZONTAL_ALIGNMENT_LEFT, -1, 14, Color(0.85, 0.70, 0.28))
		else:
			_udraw(font, Vector2(px + pw - 70, iy + 48), reward_str, HORIZONTAL_ALIGNMENT_CENTER, -1, 14, Color(0.85, 0.70, 0.28))
		# Improvement 18: Reroll button (small X on uncompleted quests)
		if not completed and not claimed:
			var rr_x = px + pw - 24.0
			var rr_y = iy + ih - 18.0
			var rr_sz = 44.0 if _is_mobile else 16.0
			var rr_hov = _is_hover_or_pressed(Rect2(rr_x - rr_sz * 0.5, rr_y - rr_sz * 0.5, rr_sz, rr_sz), mouse_pos)
			if rr_hov:
				draw_circle(Vector2(rr_x, rr_y), 9, Color(0.3, 0.15, 0.1, 0.6))
				_udraw(font, Vector2(rr_x, rr_y + 5), "X", HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.9, 0.4, 0.3))
	# --- Improvement 12: Weekly quests section ---
	card_y += 8.0
	draw_rect(Rect2(px + 20, card_y, pw - 40, 1), Color(0.4, 0.7, 0.3, 0.25))
	card_y += 6.0
	_udraw(font, Vector2(px + pw * 0.5, card_y + 14), "WEEKLY QUESTS", HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.3, 0.6, 0.85))
	card_y += 22.0
	for i in range(weekly_quests.size()):
		var wq = weekly_quests[i]
		var iy = card_y
		var ih = 52.0
		card_y += ih + 4.0
		var completed = wq.get("completed", false)
		var claimed = wq.get("claimed", false)
		var bg = Color(0.06, 0.10, 0.18, 0.55) if claimed else (Color(0.10, 0.18, 0.24, 0.72) if completed else Color(0.10, 0.09, 0.14, 0.65))
		draw_rect(Rect2(px + 8, iy, pw - 16, ih), bg)
		draw_rect(Rect2(px + 8, iy, pw - 16, ih), Color(0.3, 0.5, 0.8, 0.25), false, 1.0)
		# Weekly badge (rounded)
		draw_colored_polygon(_rrp(Rect2(px + 10, iy + 2, 60, 18), 5.0), Color(0.2, 0.4, 0.7, 0.3))
		_ds_outlined_text(Vector2(px + 40, iy + 15), "WEEKLY", 14, Color(0.4, 0.65, 0.9), -1, HORIZONTAL_ALIGNMENT_CENTER, 1)
		_udraw(font, Vector2(px + 16, iy + 28), wq.get("desc", ""), HORIZONTAL_ALIGNMENT_LEFT, int(pw - 150), 13, Color(0.75, 0.75, 0.85) if not claimed else Color(0.4, 0.4, 0.45))
		# Progress
		var pct = float(wq.get("progress", 0)) / float(max(1, wq.get("target", 1)))
		var bar_w = 100.0
		var bar_x = px + pw - 120.0
		draw_colored_polygon(_rrp(Rect2(bar_x, iy + 6, bar_w, 12), 4.0), Color(0.12, 0.12, 0.12))
		var _qbar_fill = bar_w * clampf(pct, 0.0, 1.0)
		if _qbar_fill > 6.0:
			draw_colored_polygon(_rrp(Rect2(bar_x, iy + 6, _qbar_fill, 12), 4.0), Color(0.4, 0.25, 0.60) if not claimed else Color(0.12, 0.08, 0.20))
		elif _qbar_fill > 0.0:
			draw_rect(Rect2(bar_x, iy + 6, _qbar_fill, 12), Color(0.4, 0.25, 0.60) if not claimed else Color(0.12, 0.08, 0.20))
		_udraw(font, Vector2(bar_x + bar_w * 0.5, iy + 16), "%d/%d" % [wq.get("progress", 0), wq.get("target", 1)], HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.8, 0.85, 0.9))
		var reward_str = "+%d %s" % [wq.get("reward_amount", 0), wq.get("reward_type", "").capitalize()]
		if claimed:
			_udraw(font, Vector2(px + pw - 70, iy + 42), "CLAIMED", HORIZONTAL_ALIGNMENT_CENTER, -1, 14, Color(0.3, 0.45, 0.6))
		elif completed:
			var claim_pulse = 0.7 + sin(_time * 4.0 + float(i) + 5.0) * 0.3
			var btn_x = px + pw - 115.0
			var btn_y = iy + 28.0
			var wclaim_h = 44.0 if _is_mobile else 20.0
			var btn_hov = _is_hover_or_pressed(Rect2(btn_x, btn_y, 95, wclaim_h), mouse_pos)
			_ds_button(Rect2(btn_x, btn_y, 95, wclaim_h), "CLAIM!", Color(0.14, 0.10, 0.24), btn_hov, 13)
			_udraw(font, Vector2(px + 16, iy + 42), reward_str, HORIZONTAL_ALIGNMENT_LEFT, -1, 13, Color(0.85, 0.70, 0.28))
		else:
			_udraw(font, Vector2(px + pw - 70, iy + 42), reward_str, HORIZONTAL_ALIGNMENT_CENTER, -1, 13, Color(0.85, 0.70, 0.28))
	# Improvement 13: Streak reward progress
	card_y += 8.0
	var next_streak = 0
	var next_streak_reward = 0
	for s in [3, 7, 14, 30]:
		if quest_streak < s:
			next_streak = s
			next_streak_reward = QUEST_STREAK_REWARDS[s]
			break
	if next_streak > 0:
		_udraw(font, Vector2(px + pw * 0.5, card_y + 14), "Streak bonus at %d days: +%d Shards" % [next_streak, next_streak_reward], HORIZONTAL_ALIGNMENT_CENTER, int(pw - 30), 14, Color(0.55, 0.65, 0.4))
	else:
		_udraw(font, Vector2(px + pw * 0.5, card_y + 14), "Max streak bonus reached!", HORIZONTAL_ALIGNMENT_CENTER, -1, 14, Color(0.7, 0.85, 0.4))

